# Local data / caches (per-day JSON IS committed; transient pulls are not)
data/_cache/
*.local.json
.DS_Store

# Rendered site is built locally (Mac-local arch) and opened in a browser; keep
# ALL local builds out of git. Invariant: site/ is never committed (incl.
# site/.nojekyll, which render.py recreates each run).
/site/

# Local run logs (compute.command / launchd). Transient — never committed.
/logs/
